# ---------------------------------------------------------------------------
# Supabase (projeto novo e dedicado ao PosteiFlow)
# ---------------------------------------------------------------------------
# Settings > API > Project URL
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Settings > API > service_role key (secreta — nunca exponha no client)
SUPABASE_SERVICE_KEY=

# As duas abaixo são usadas SÓ no browser, exclusivamente para o upload de
# vídeo ir direto para o Supabase Storage (contorna o limite de tamanho de
# corpo de requisição das Serverless Functions da Vercel). NEXT_PUBLIC_* fica
# embutido no bundle do client — é esperado e seguro: a anon key não dá acesso
# a nenhuma tabela (RLS habilitado sem policies) e o upload só funciona com o
# token assinado gerado pelo servidor.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Settings > API > anon / public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Instagram API with Instagram Login (graph.instagram.com) — app PosteiFlow-IG
# ---------------------------------------------------------------------------
# Não usado diretamente pelas chamadas de API implementadas (a troca de token
# usa só client_secret), mantido aqui só como referência do app no Meta.
IG_APP_ID=
IG_APP_SECRET=
IG_USER_ID=17841448692415302
# Token gerado no painel do Meta. Pode ser um short-lived clássico (~1h) OU
# já um long-lived (alguns fluxos do painel emitem direto) — o "Conectar" em
# Configurações lida com os dois casos automaticamente (troca -> renovação
# direta -> fallback; veja README seção 6). Só é lido no momento de clicar em
# "Conectar"/"Reconectar" — depois disso o app usa o token salvo no banco.
#
# Atenção: se você (ou alguém) testar ig_refresh_token manualmente fora do
# app (ex: via curl, para debug), a Meta pode rotacionar/invalidar este
# token. Se "Conectar" passar a falhar com erro de token inválido sem
# nenhuma mudança de código, gere um token fresco no painel e cole aqui de
# novo antes de suspeitar de bug.
IG_ACCESS_TOKEN=
# Opcional — versão da Graph API a usar. Ajuste se a Meta depreciar a atual.
IG_GRAPH_API_VERSION=v25.0

# ---------------------------------------------------------------------------
# Basic Auth (protege TODO o app, exceto /api/cron/*) — uso pessoal/single-user
# Gere uma senha forte, ex: node -e "console.log(require('crypto').randomBytes(18).toString('base64url'))"
# Sem essas duas vars definidas, o proxy nega acesso a tudo (fail closed).
# ---------------------------------------------------------------------------
APP_USERNAME=
APP_PASSWORD=

# ---------------------------------------------------------------------------
# Cron (protege /api/cron/*) — gere um valor aleatório qualquer
# ---------------------------------------------------------------------------
CRON_SECRET=

# ---------------------------------------------------------------------------
# Telegram (opcional) — alerta ~7 dias antes do token do Instagram expirar
# Deixe em branco para desativar o alerta sem erro.
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
